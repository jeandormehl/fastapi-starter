generator client {
  interface                   = "asyncio"
  provider                    = "prisma-client-py"
  recursive_type_depth        = 3
  enable_experimental_decimal = true
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id            String   @id @default(cuid())
  client_id     String   @unique
  name          String
  hashed_secret String
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  scopes Scope[] @relation("clients_scopes")

  @@map("clients")
}

model Scope {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?

  clients Client[] @relation("clients_scopes")

  @@map("scopes")
}

model RequestLog {
  id               String    @id @default(cuid())
  trace_id         String
  request_id       String    @unique
  auth_method      String?
  authenticated    Boolean   @default(false)
  body             Json?
  client_id        String?
  client_ip        String?
  content_length   Int?
  content_type     String?
  duration_ms      Decimal?
  end_time         DateTime?
  error_category   String?
  error_occurred   Boolean   @default(false)
  error_type       String?
  has_bearer_token Boolean   @default(false)
  headers          Json?
  logged_at        DateTime  @default(now())
  path             String
  path_params      Json?
  query_params     Json?
  request_method   String
  request_url      String
  response_body    Json?
  response_headers Json?
  response_size    Int?
  response_type    String?
  scopes           String[]  @default([])
  start_time       DateTime
  status_code      Int?
  success          Boolean   @default(false)
  user_agent       String?

  created_at DateTime @default(now())

  @@index([trace_id])
  @@index([request_id])
  @@index([request_method, path])
  @@index([status_code])
  @@index([start_time])
  @@index([client_ip])
  @@map("request_logs")
}

model TaskLog {
  id                    String    @id @default(cuid())
  task_id               String    @unique
  task_name             String
  trace_id              String?
  request_id            String?
  worker_id             String?
  app_version           String?
  broker_type           String?
  completed_at          DateTime?
  cpu_usage_percent     Decimal?
  duration_ms           Decimal?
  error_category        String?
  error_message         String?
  error_occurred        Boolean   @default(false)
  error_type            String?
  execution_environment String?
  logged_at             DateTime  @default(now())
  max_retries           Int?
  memory_usage_mb       Decimal?
  priority              Int?
  queue                 String?
  retry_count           Int       @default(0)
  started_at            DateTime?
  status                String // pending, running, success, failed, cancelled
  submitted_at          DateTime
  task_args             Json?
  task_error            Json?
  task_kwargs           Json?
  task_labels           Json?
  task_result           Json?

  created_at DateTime @default(now())

  @@index([task_id])
  @@index([task_name])
  @@index([trace_id])
  @@index([status])
  @@index([submitted_at])
  @@index([started_at])
  @@map("task_logs")
}
