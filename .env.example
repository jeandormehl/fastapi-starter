APP_NAME="fastapi-starter"
APP_DESCRIPTION="FastAPI Starter Project"
APP_ENVIRONMENT="local"
APP_SECRET_KEY=""
APP_TIMEZONE="UTC"

ADMIN_CLIENT_ID="admin-id" # ideally an uuid
ADMIN_PASSWORD="password"

API_CORS_ORIGINS=["*"]
API_ALLOWED_HOSTS=["*"]
API_HOST="0.0.0.0"
API_PORT="8080"

CLOUD_PROVIDER=""

DATABASE_URL="postgresql://postgres:postgres@postgres:5432/postgres"

LOG_LEVEL="DEBUG"
LOG_TO_FILE="True"
LOG_FILE_PATH="/app/static/logs/app.log"
LOG_ENABLE_JSON="False"

PARSEABLE_ENABLED="True"
PARSEABLE_URL="http://parseable:8000"
PARSEABLE_USERNAME="admin"
PARSEABLE_PASSWORD="password"
PARSEABLE_BATCH_SIZE="100"
PARSEABLE_FLUSH_INTERVAL="5.0"
PARSEABLE_MAX_RETRIES="3"
PARSEABLE_RETRY_DELAY="1.0"

JWT_ALGORITHM="HS256"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES="60"

TASKIQ_BROKER_TYPE="redis"
TASKIQ_BROKER_URL="redis://:redis@redis:6379/0"
TASKIQ_RESULT_BACKEND_URL="redis://:redis@redis:6379/1"

REQUEST_LOGGING_ENABLED="True"
REQUEST_LOGGING_LOG_HEADERS="True"
REQUEST_LOGGING_EXCLUDED_PATHS=["/health","/metrics","/static"]
REQUEST_LOGGING_EXCLUDED_METHODS=["OPTIONS","HEAD"]
REQUEST_LOGGING_RETENTION_DAYS=90

TASK_LOGGING_ENABLED="True"

IDEMPOTENCY_ENABLED="True"

OTEL_ENABLED="True"
OTEL_EXPORTER_OTLP_ENDPOINT="http://otel-collector:4317"
OTEL_EXPORTER_OTLP_PROTOCOL="grpc"
OTEL_RESOURCE_ATTRIBUTES="service.name=fastapi-starter,service.version=1.0.0"
OTEL_TRACES_ENABLED="True"
OTEL_METRICS_ENABLED="True"
OTEL_TRACES_SAMPLE_RATE="1.0"
