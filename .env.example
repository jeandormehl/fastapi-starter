APP_NAME="fastapi-starter"
APP_DESCRIPTION="FastAPI Starter Project"
APP_ENVIRONMENT="local"
APP_SECRET_KEY=""
APP_TIMEZONE="UTC"

ADMIN_PASSWORD="password"

API_CORS_ORIGINS=["*"]
API_ALLOWED_HOSTS=["*"]
API_HOST="0.0.0.0"
API_PORT="8080"

CLOUD_PROVIDER=""

DATABASE_URL="postgresql://postgres:postgres@postgres:5432/postgres"

LOG_LEVEL="DEBUG"
LOG_TO_FILE="True"
LOG_FILE_PATH="/app/static/logs/app.log"
LOG_ENABLE_JSON="False"

PARSEABLE_ENABLED="True"
PARSEABLE_URL="http://parseable:8000"
PARSEABLE_STREAM="fastapi-starter-logs"
PARSEABLE_USERNAME="admin"
PARSEABLE_PASSWORD="password"
PARSEABLE_BATCH_SIZE="100"
PARSEABLE_FLUSH_INTERVAL="5.0"
PARSEABLE_MAX_RETRIES="3"
PARSEABLE_RETRY_DELAY="1.0"

JWT_ALGORITHM="HS256"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES="60"

TASKIQ_BROKER_TYPE="redis"
TASKIQ_BROKER_URL="redis://:redis@redis:6379/0"
TASKIQ_RESULT_BACKEND_URL="redis://:redis@redis:6379/1"
