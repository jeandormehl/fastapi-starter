APP_NAME="Test FastAPI Starter"
APP_DESCRIPTION="Test API for FastAPI Starter"
APP_ENVIRONMENT="test"
APP_SECRET_KEY="test-secret-key-very-long-and-secure-for-comprehensive-testing"
APP_TIMEZONE="UTC"

# Database settings - use in-memory SQLite for tests
DATABASE_URL="sqlite:///:memory:"

# Logging settings - disable all logging output during tests
LOG_LEVEL="CRITICAL"
LOG_TO_FILE="False"
LOG_ENABLE_JSON="False"

# Parseable settings - completely disabled for tests
PARSEABLE_ENABLED="False"
PARSEABLE_URL="http://localhost:8000"
PARSEABLE_STREAM="test-stream"
PARSEABLE_USERNAME="test"
PARSEABLE_PASSWORD="test"

# JWT settings
JWT_ALGORITHM="HS256"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES="30"

# Request logging - disabled for tests
REQUEST_LOGGING_ENABLED="False"
REQUEST_LOGGING_LOG_HEADERS="False"
REQUEST_LOGGING_RETENTION_DAYS="1"

# Admin settings
ADMIN_PASSWORD="test-admin-password-very-secure-for-testing"

# API settings
API_CORS_ORIGINS='["*"]'
API_ALLOWED_HOSTS='["*"]'
API_HOST="127.0.0.1"
API_PORT="8080"
